# marketcast configuration — copy to `.env` and fill in.
# Nothing here is required to run the Polymarket data layer; the X (research /
# template) and LLM features degrade gracefully when their secrets are absent.

# --- X / Twitter -------------------------------------------------------------
# auth_token cookie from a logged-in x.com session
# (DevTools -> Application -> Cookies -> auth_token). Used by the xclient library
# for fetching reference tweets and live research.
AUTH_TOKEN=

# Optional outbound proxy for X requests, e.g. http://user:pass@host:port
PROXY=

# --- LLM ---------------------------------------------------------------------
# Path to a file with one NVIDIA build API key per line (Kimi fallback provider).
# duck.ai is the keyless primary provider and needs no secret here.
NVIDIA_KEYS_FILE=nvidia_keys.txt

# Override the Kimi fallback model id.
KIMI_MODEL=moonshotai/kimi-k2.6

# Set to 1 to skip duck.ai entirely and use the Kimi fallback directly.
DISABLE_DUCK=0

# Node binary used to refresh the duck.ai browser session.
NODE_BIN=node

# --- pipeline ----------------------------------------------------------------
# Set to 1 to skip live X research during post generation.
DISABLE_RESEARCH=0

# Where generation logs / history caches are written (default: ./data).
MARKETCAST_DATA_DIR=data
